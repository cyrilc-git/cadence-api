# Cadence — variables d'environnement
# Copie ce fichier en .env.local et remplis avec tes valeurs depuis Vercel
# (Vercel Dashboard → cadence-api → Settings → Environment Variables)

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE — Supabase Postgres + pgvector
# ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://hzbsvnubmnqsbsgcblfv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_remplir_depuis_vercel
SUPABASE_SERVICE_ROLE_KEY=eyJ_remplir_depuis_vercel

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE — Chiffrement credentials AES-256-GCM
# 32 bytes hex = 64 caractères. Doit matcher la prod sinon impossible
# de lire/décrypter les credentials déjà stockés.
# ──────────────────────────────────────────────────────────────────
CADENCE_CRYPTO_KEY=remplir_depuis_vercel

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE pour publier — LinkedIn OAuth
# Si tu travailles en local, mets http://localhost:3000/... dans redirect.
# Pense à l'ajouter dans la console LinkedIn Developer.
# ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=remplir_depuis_vercel
LINKEDIN_CLIENT_SECRET=remplir_depuis_vercel
LINKEDIN_REDIRECT_URI=https://cadence-api-ruddy.vercel.app/api/auth/linkedin/callback

# ──────────────────────────────────────────────────────────────────
# OPTIONNEL — Anthropic + OpenAI
# Si non set, Cadence lit depuis la table 'credentials' en DB
# (chiffrées via CADENCE_CRYPTO_KEY). Override possible :
# ──────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────
# OPTIONNEL — GitHub pour le Radar de signaux produit
# ──────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_REPOS=cyrilc-git/cadence-api,cyrilc-git/heelio-decode
