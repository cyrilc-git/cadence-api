# Cadence — variables d'environnement
# Copie ce fichier en .env.local et remplis avec tes valeurs depuis Vercel
# (Vercel Dashboard → cadence-api → Settings → Environment Variables)

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE — Supabase Postgres + pgvector
# ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://hzbsvnubmnqsbsgcblfv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ_remplir_depuis_vercel
SUPABASE_ANON_KEY=eyJ_remplir_depuis_vercel

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE — Chiffrement des credentials en DB (AES-256-GCM)
# Doit matcher EXACTEMENT la valeur prod sinon impossible de lire
# les credentials Notion / Anthropic / OpenAI déjà stockés.
# ──────────────────────────────────────────────────────────────────
MASTER_ENCRYPTION_KEY=remplir_depuis_vercel

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE — Notion (source de vérité des posts)
# ──────────────────────────────────────────────────────────────────
NOTION_API_TOKEN=secret_remplir_depuis_vercel
NOTION_LINKEDIN_DS_ID=remplir_depuis_vercel

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE — LinkedIn OAuth
# Pour le local, change le redirect en http://localhost:3000/...
# et ajoute cette URL dans la console LinkedIn Developer.
# ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=remplir_depuis_vercel
LINKEDIN_CLIENT_SECRET=remplir_depuis_vercel
LINKEDIN_REDIRECT_URI=https://cadence-api-ruddy.vercel.app/api/auth/linkedin/callback

# ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE — Secrets internes (cron + publish API)
# ──────────────────────────────────────────────────────────────────
CRON_SECRET=remplir_depuis_vercel
COCKPIT_SECRET=remplir_depuis_vercel

# ──────────────────────────────────────────────────────────────────
# OPTIONNEL — Anthropic + OpenAI
# Si absent en env, Cadence lit depuis la table 'credentials' en DB
# (chiffrée via MASTER_ENCRYPTION_KEY). Override possible :
# ──────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────
# OPTIONNEL — GitHub pour le Radar de signaux produit
# ──────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_REPOS=cyrilc-git/cadence-api,cyrilc-git/heelio-decode
